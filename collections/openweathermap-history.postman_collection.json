      "name": "History",
      "description": {
        "content": "Historical weather records by coordinate with hourly granularity.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "086563d1-a837-4e1a-ab27-32bda802a5dc",
          "name": "Historical Hourly Weather By Coordinate",
          "request": {
            "name": "Historical Hourly Weather By Coordinate",
            "description": {
              "content": "Returns hourly historical weather records for the supplied latitude, longitude, and time window. Maximum request span on Professional and Expert plans is one week per call.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "history",
                "city"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "lat",
                  "value": "<float>",
                  "description": "(Required) Latitude in decimal degrees."
                },
                {
                  "disabled": false,
                  "key": "lon",
                  "value": "<float>",
                  "description": "(Required) Longitude in decimal degrees."
                },
                {
                  "disabled": false,
                  "key": "type",
                  "value": "<string>",
                  "description": "(Required) Granularity. Currently only `hour` is supported."
                },
                {
                  "disabled": false,
                  "key": "start",
                  "value": "<long>",
                  "description": "Unix UTC start timestamp."
                },
                {
                  "disabled": false,
                  "key": "end",
                  "value": "<long>",
                  "description": "Unix UTC end timestamp. Alternative to `cnt`."
                },
                {
                  "disabled": false,
                  "key": "cnt",
                  "value": "<integer>",
                  "description": "Number of hourly timestamps to return. Alternative to `end`."
                },
                {
                  "disabled": false,
                  "key": "units",
                  "value": "<string>"
                },
                {
                  "disabled": false,
                  "key": "appid",
                  "value": "<string>",
                  "description": "(Required) OpenWeather API key."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
