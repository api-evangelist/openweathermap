                "interval_data"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "lat",
                  "value": "<float>",
                  "description": "(Required) Latitude in decimal degrees, range -90 to 90."
                },
                {
                  "disabled": false,
                  "key": "lon",
                  "value": "<float>",
                  "description": "(Required) Longitude in decimal degrees, range -180 to 180."
                },
                {
                  "disabled": false,
                  "key": "date",
                  "value": "<date>",
                  "description": "(Required) Date in YYYY-MM-DD format. Available from 1979-01-01 up to plus 15 days."
                },
                {
                  "disabled": false,
                  "key": "interval",
                  "value": "<string>",
                  "description": "Time resolution."
                },
                {
                  "disabled": false,
                  "key": "tz",
                  "value": "<string>",
                  "description": "Timezone in +-HH:MM format."
                },
                {
                  "disabled": false,
                  "key": "appid",
