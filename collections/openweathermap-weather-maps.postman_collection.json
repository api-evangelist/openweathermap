  "info": {
    "_postman_id": "e7c84b71-4230-4826-939d-133e066ba204",
    "name": "OpenWeatherMap Weather Maps 1.0 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Tile map service that overlays weather data layers (clouds, precipitation, pressure, wind, temperature) on top of base maps using standard z/x/y tile coordinates. Compatible with Leaflet, OpenLayers, Google Maps, and other tile-based libraries.\n\nContact Support:\n Name: OpenWeather",
      "type": "text/plain"
    }
