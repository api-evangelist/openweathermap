          "name": "Current Weather Data For A Coordinate",
          "request": {
            "name": "Current Weather Data For A Coordinate",
            "description": {
              "content": "Returns current weather data for the supplied latitude and longitude. Data includes temperature, atmospheric pressure, humidity, visibility, wind, cloudiness, sunrise and sunset times, and a brief weather condition.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "weather"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "lat",
                  "value": "<float>",
                  "description": "(Required) Latitude in decimal degrees, range -90 to 90."
                },
                {
                  "disabled": false,
                  "key": "lon",
                  "value": "<float>",
                  "description": "(Required) Longitude in decimal degrees, range -180 to 180."
                },
                {
                  "disabled": false,
                  "key": "mode",
                  "value": "<string>",
                  "description": "Response format. Default is JSON. Use xml or html for alternative formats."
                },
                {
                  "disabled": false,
                  "key": "units",
                  "value": "<string>",
                  "description": "Units of measurement. standard (Kelvin), metric (Celsius), or imperial (Fahrenheit)."
                },
                {
                  "disabled": false,
                  "key": "lang",
                  "value": "<string>",
                  "description": "Localization language code for the weather condition output text."
                },
                {
                  "disabled": false,
                  "key": "appid",
                  "value": "<string>",
                  "description": "(Required) OpenWeather API key."
                }
              ],
              "variable": []
            },
            "header": [
