      "name": "direct",
      "item": [
        {
          "name": "Direct Geocoding By Location Name",
          "id": "17ccd36c-11ea-4d0e-9fe1-695306fc0340",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/direct?q=<string>&limit=<integer>&appid=<string>",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "direct"
              ],
              "query": [
                {
                  "description": "(Required) City name, optional state and country codes, comma-separated.",
                  "key": "q",
                  "value": "<string>"
                },
                {
                  "description": "Maximum number of locations to return. Up to 5.",
                  "key": "limit",
                  "value": "<integer>"
                },
                {
                  "description": "(Required) OpenWeather API key.",
                  "key": "appid",
                  "value": "<string>"
                }
              ]
            },
            "description": "Returns geographic coordinates for a location specified by city name, optional state code (US only), and optional ISO 3166 country code."
          },
          "response": [
            {
              "id": "d5420486-50be-4a81-bf31-44a8c6622921",
