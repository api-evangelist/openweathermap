    "_postman_id": "2ba11998-0fcd-4b34-b093-21d8f434fa28",
    "name": "OpenWeatherMap Geocoding API",
    "description": "Direct and reverse geocoding for city names, zip codes, and coordinate pairs. Supports city, state, country, and area-level resolution and is used to convert between location text and geographic coordinates.\n\nContact Support:\n Name: OpenWeather",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:18:53.000Z",
