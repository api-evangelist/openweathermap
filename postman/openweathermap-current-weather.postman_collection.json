      "item": [
        {
          "name": "Current Weather Data For A Coordinate",
          "id": "c94ff984-5f51-4aa1-8192-82a198ad071e",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/weather?lat=<float>&lon=<float>&mode=json&units=standard&lang=<string>&appid=<string>",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "weather"
              ],
              "query": [
                {
                  "description": "(Required) Latitude in decimal degrees, range -90 to 90.",
                  "key": "lat",
                  "value": "<float>"
                },
                {
                  "description": "(Required) Longitude in decimal degrees, range -180 to 180.",
                  "key": "lon",
                  "value": "<float>"
                },
                {
                  "description": "Response format. Default is JSON. Use xml or html for alternative formats.",
                  "key": "mode",
                  "value": "json"
                },
                {
                  "description": "Units of measurement. standard (Kelvin), metric (Celsius), or imperial (Fahrenheit).",
                  "key": "units",
                  "value": "standard"
                },
                {
                  "description": "Localization language code for the weather condition output text.",
                  "key": "lang",
                  "value": "<string>"
                },
                {
                  "description": "(Required) OpenWeather API key.",
                  "key": "appid",
                  "value": "<string>"
                }
              ]
            },
            "description": "Returns current weather data for the supplied latitude and longitude. Data includes temperature, atmospheric pressure, humidity, visibility, wind, cloudiness, sunrise and sunset times, and a brief weather condition."
